# =============================================================================
# Copilot Sandbox — runtime configuration
# Copy this file to `.env` and fill in your values. `.env` is gitignored.
# =============================================================================

# -----------------------------------------------------------------------------
# Copilot CLI
# -----------------------------------------------------------------------------
# Default model used in programmatic mode when --model is not passed.
# Leave as "auto" to let Copilot choose.
COPILOT_DEFAULT_MODEL=auto

# -----------------------------------------------------------------------------
# Base image registry
# -----------------------------------------------------------------------------
# The base image is pulled from ${BASE_IMAGE_REGISTRY}/${BASE_IMAGE} at build
# time. Defaults reproduce a Docker Hub pull of plain Ubuntu 24.04 (the Semeru
# JDK is installed on top via tarball, since the Semeru image isn't always
# mirrored internally). To use a company registry or mirror, set
# BASE_IMAGE_REGISTRY to its host (e.g. registry.mycompany.com); the wrapper
# passes these to `docker build` automatically. Override BASE_IMAGE too if your
# registry stores the image under a different path/tag.
#BASE_IMAGE_REGISTRY=docker.io
#BASE_IMAGE=ubuntu:24.04

# -----------------------------------------------------------------------------
# Java / IBM Semeru JDK
# -----------------------------------------------------------------------------
# The Semeru (Open) JDK 21 is downloaded from a pinned release at build time.
# Override to bump the version or to point at an internal mirror.
#   SEMERU_JDK_VERSION      : release tag suffix (after "jdk-"), with "+", e.g.
#                             21.0.9+10_openj9-0.56.0
#   SEMERU_JDK_FILE_VERSION : same version as in the asset filename ("+"->"_"),
#                             e.g. 21.0.9_10_openj9-0.56.0
#   SEMERU_BASE_URL         : download host/path (point at an internal mirror to
#                             avoid reaching github.com at build time)
#SEMERU_JDK_VERSION=21.0.9+10_openj9-0.56.0
#SEMERU_JDK_FILE_VERSION=21.0.9_10_openj9-0.56.0
#SEMERU_BASE_URL=https://github.com/ibmruntimes/semeru21-binaries/releases/download

# -----------------------------------------------------------------------------
# Maven / Artifactory
# -----------------------------------------------------------------------------
# Authentication uses the JFrog CLI — NO plaintext username/password. Either:
#   • run `./copilot-sandbox jf-login` once (browser/device flow), or
#   • drop a scoped access token in a file (see ARTIFACTORY_TOKEN_FILE below).
#
# JFrog Platform URL (NOT a secret). Example: https://artifactory.mycompany.com
ARTIFACTORY_URL=https://artifactory.example.com

# Maven resolution repositories in Artifactory. Set both (use the same value if a
# single virtual repo serves releases and snapshots). Required for `mvn` to route
# through Artifactory; if unset, `mvn` falls back to its defaults.
ARTIFACTORY_REPO_RESOLVE_RELEASES=maven-virtual
ARTIFACTORY_REPO_RESOLVE_SNAPSHOTS=maven-virtual

# Fallback only: path (host-side) to a file containing a scoped Artifactory access
# token. If the file exists it is mounted read-only and configured via stdin — the
# token never appears in env vars or `docker inspect`. Relative paths resolve from
# the repo root. Default: secrets/artifactory-token (gitignored).
#ARTIFACTORY_TOKEN_FILE=secrets/artifactory-token

# -----------------------------------------------------------------------------
# MCP servers (company MCP registry)
# -----------------------------------------------------------------------------
# npm-compatible registry used to install npx-based MCP servers.
# Example: https://artifactory.mycompany.com/artifactory/api/npm/npm-virtual
MCP_NPM_REGISTRY=https://registry.npmjs.org

# OCI/Docker registry used for container-based MCP servers (optional).
MCP_OCI_REGISTRY=

# -----------------------------------------------------------------------------
# Azure DevOps
# -----------------------------------------------------------------------------
# Your Azure DevOps organization name (the "ORG" in dev.azure.com/ORG).
AZURE_DEVOPS_ORG=my-org
